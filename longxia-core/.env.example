# ==========================================
# 龙虾特战队 - 全栈智能体协同网络配置
# ==========================================

# 1. 基础服务配置
PORT=8080
WEBSOCKET_PORT=8081
REDIS_URL=redis://localhost:6379/0

# 2. 核心大模型配置 (LLM Routing)
# 本地 5090 模型服务 (VLLM / Ollama)
LOCAL_LLM_API_BASE=http://localhost:11434/v1
LOCAL_LLM_API_KEY=sk-local-dev

# 云端回退模型 (Fallback)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxx
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# 3. 生态工具配置 (OpenClaw / 第三方授权)
SLACK_BOT_TOKEN=xoxb-xxxxxxxxx
NOTION_API_KEY=secret_xxxxxxxx

# 4. 多媒体与数字人视频渲染框架依赖
# 龙虾系统内置对外部多模态框架的适配封装，部署时请视需求配置
HEYGEN_API_KEY=xxxx-xxxx-xxxx-xxxx
RUNWAY_API_KEY=xxxx-xxxx-xxxx
WAV2LIP_LOCAL_CHECKPOINT_DIR=/path/to/wav2lip/weights

# 5. 展会高压配置
ENABLE_HITL_DIRECTOR_MODE=true
ENGINE_TIMEOUT_MS=60000
MAX_RETRIES_ON_TOOL_FAIL=2
